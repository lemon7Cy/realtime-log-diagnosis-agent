# ===== LLM 配置 =====
LLM_PROVIDER=claude
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=
LLM_MODEL=claude-sonnet-4-20250514
LLM_TIMEOUT=120

# ===== 应用配置 =====
APP_LOG_LEVEL=INFO
APP_LOG_FORMAT=text

# ===== CORS =====
CORS_ALLOWED_ORIGINS=http://localhost:3003

# ===== 日志源 =====
LOG_SOURCE_FILE=data/sample_app.log
ANOMALY_WINDOW_SECONDS=120
ANOMALY_MIN_5XX_COUNT=3
ANOMALY_ERROR_RATE_THRESHOLD=0.30
